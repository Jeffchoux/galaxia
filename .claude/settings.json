{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "touch /tmp/claude-max-active.lock 2>/dev/null; true"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "touch /tmp/claude-max-active.lock 2>/dev/null; true"
          }
        ]
      }
    ]
  }
}
